---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
  href: string;
  buttonText: string;
  reverse?: boolean;
}

const { title, description, image, imageAlt, href, buttonText, reverse = false } = Astro.props;
---

<section class:list={['teaser', { 'teaser--reverse': reverse }]}>
  <div class="teaser__image-wrap">
    <Image
      src={image}
      alt={imageAlt}
      class="teaser__image"
      widths={[400, 700, 1000]}
      sizes="(max-width: 768px) 100vw, 50vw"
    />
  </div>
  <div class="teaser__content">
    <h2 class="teaser__title">{title}</h2>
    <p class="teaser__desc">{description}</p>
    <a href={href} class="teaser__btn">{buttonText}</a>
  </div>
</section>

<style>
  .teaser {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .teaser--reverse {
    flex-direction: row-reverse;
  }

  .teaser__image-wrap {
    flex: 1;
    overflow: hidden;
    border-radius: 8px;
  }

  .teaser__image {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 8px;
    transition: transform 0.4s ease;
  }

  .teaser__image-wrap:hover .teaser__image {
    transform: scale(1.03);
  }

  .teaser__content {
    flex: 1;
  }

  .teaser__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 2.5rem);
    color: var(--navy);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .teaser__desc {
    color: var(--gray);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-top: 1rem;
  }

  .teaser__btn {
    display: inline-block;
    margin-top: 1.5rem;
    background: var(--red);
    color: var(--white);
    padding: 0.75rem 2rem;
    border-radius: 24px;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.2s ease;
  }

  .teaser__btn:hover {
    background: #c42a52;
  }

  @media (max-width: 768px) {
    .teaser,
    .teaser--reverse {
      flex-direction: column;
    }

    .teaser__image {
      height: 240px;
    }
  }
</style>
