---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
}
const { images } = Astro.props;
---

<div class="photo-strip">
  {images.map((img, i) => (
    <div class="photo-strip__item">
      <Image
        src={img}
        alt={`MCU foto ${i + 1}`}
        class="photo-strip__img"
        widths={[300, 500]}
        sizes="(max-width: 768px) 48vw, 25vw"
      />
    </div>
  ))}
</div>

<style>
  .photo-strip {
    display: flex;
    gap: 4px;
    padding: 4px;
    overflow: hidden;
  }

  .photo-strip__item {
    flex: 1;
    overflow: hidden;
  }

  .photo-strip__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 2px;
    transition: transform 0.3s ease;
    display: block;
  }

  .photo-strip__item:hover .photo-strip__img {
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .photo-strip {
      flex-wrap: wrap;
    }

    .photo-strip__item {
      flex: 0 0 calc(48% - 2px);
    }

    .photo-strip__img {
      height: 150px;
    }
  }
</style>
