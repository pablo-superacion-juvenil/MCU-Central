---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  height?: string;
  mobileHeight?: string;
  position?: string;
}

const {
  image,
  alt,
  height = '450px',
  mobileHeight = '250px',
  position = 'center',
} = Astro.props;
---

<div
  class="photo-divider"
  style={`--divider-height: ${height}; --divider-mobile-height: ${mobileHeight}; --divider-position: ${position};`}
>
  <Image
    src={image}
    alt={alt}
    class="photo-divider__img"
    widths={[600, 1000, 1600]}
    sizes="100vw"
  />
</div>

<style>
  .photo-divider {
    width: 100%;
    height: var(--divider-height, 450px);
    overflow: hidden;
  }

  .photo-divider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--divider-position, center);
  }

  @media (max-width: 768px) {
    .photo-divider {
      height: var(--divider-mobile-height, 250px);
    }
  }
</style>
