---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
}

const { image, alt } = Astro.props;
---

<div class="photo-divider">
  <Image
    src={image}
    alt={alt}
    class="photo-divider__img"
    widths={[600, 1000, 1600]}
    sizes="100vw"
  />
</div>

<style>
  .photo-divider {
    width: 100%;
    height: 350px;
    overflow: hidden;
  }

  .photo-divider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .photo-divider {
      height: 220px;
    }
  }
</style>
