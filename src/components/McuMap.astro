  <div class="mcu-list">
    <div class="mcu-list-grid">
      {locations.filter(l => l.handle).map(loc => (
        <a href={loc.instagram} target="_blank" rel="noopener noreferrer" class="mcu-list-item">
          <span class="mcu-list-icon"><Instagram size={18} /></span>
          <div class="mcu-list-info">
            <span class="mcu-list-name">{loc.name}</span>
            <span class="mcu-list-handle">{loc.handle}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ locations, clusters }}>
  const wrapper = document.getElementById('map-wrapper');
  const popup = document.getElementById('map-popup');
  const popupContent = document.getElementById('popup-content');
  const popupClose = document.getElementById('popup-close');

  function showPopup(items, anchorEl) {
    const html = items.map(item => {
      if (!item.handle) return `<div class="popup-item"><strong>${item.name}</strong></div>`;
      return `
        <a href="${item.instagram}" target="_blank" rel="noopener noreferrer" class="popup-item popup-item--link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          <div>
            <strong>${item.name}</strong>
            <span class="popup-handle">${item.handle}</span>
          </div>
        </a>
      `;
    }).join('');

    popupContent.innerHTML = html;
    popup.setAttribute('aria-hidden', 'false');
    popup.classList.add('is-visible');

    const wrapperRect = wrapper.getBoundingClientRect();
    const markerRect = anchorEl.getBoundingClientRect();
    const markerCenterX = markerRect.left + markerRect.width / 2 - wrapperRect.left;
    const markerTop = markerRect.top - wrapperRect.top;

    popup.style.left = `${markerCenterX}px`;
    popup.style.top = `${markerTop - 10}px`;

    const popupRect = popup.getBoundingClientRect();
    if (popupRect.left < wrapperRect.left) {
      popup.style.left = `${popup.offsetWidth / 2 + 8}px`;
    }
    if (popupRect.right > wrapperRect.right) {
      popup.style.left = `${wrapperRect.width - popup.offsetWidth / 2 - 8}px`;
    }
    if (popupRect.top < wrapperRect.top) {
      popup.style.top = `${markerTop + markerRect.height + 10}px`;
      popup.classList.add('popup--below');
    } else {
      popup.classList.remove('popup--below');
    }
  }

  function hidePopup() {
    popup.classList.remove('is-visible');
    popup.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll('.map-marker').forEach(marker => {
    marker.addEventListener('click', (e) => {
      e.stopPropagation();
      const locId = marker.dataset.location;
      const loc = locations.find(l => l.id === locId);
      if (loc) showPopup([loc], marker);
    });
  });

  document.querySelectorAll('.map-cluster').forEach(cluster => {
    cluster.addEventListener('click', (e) => {
      e.stopPropagation();
      const clusterId = cluster.dataset.cluster;
      const items = locations.filter(l => l.cluster === clusterId);
      if (items.length) showPopup(items, cluster);
    });
  });

  popupClose?.addEventListener('click', (e) => {
    e.stopPropagation();
    hidePopup();
  });

  document.addEventListener('click', (e) => {
    if (!popup.contains(e.target)) hidePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hidePopup();
  });
</script>

<style>
  .mcu-map-section {
    padding: 3rem 1.5rem 5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .mcu-map-container {
    display: block;
  }

  .map-wrapper {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .mexico-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .mexico-state {
    fill: var(--navy);
    stroke: rgba(255, 255, 255, 0.25);
    stroke-width: 1;
    stroke-linejoin: round;
  }

  /* ── Markers ───────────────────────────────────────────── */
  .markers-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .map-marker {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 28px;
    height: 28px;
    border: none;
    background: none;
    cursor: pointer;
    pointer-events: all;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .marker-dot {
    display: block;
    width: 12px;
    height: 12px;
    background: var(--red);
    border: 2px solid var(--white);
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .map-marker:hover .marker-dot,
  .map-marker:focus .marker-dot {
    transform: scale(1.4);
    box-shadow: 0 2px 10px rgba(230, 52, 98, 0.5);
  }

  .map-cluster {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 36px;
    height: 36px;
    background: var(--red);
    border: 2px solid var(--white);
    border-radius: 50%;
    cursor: pointer;
    pointer-events: all;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    padding: 0;
  }

  .map-cluster:hover,
  .map-cluster:focus {
    transform: translate(-50%, -50%) scale(1.15);
    box-shadow: 0 4px 14px rgba(230, 52, 98, 0.5);
  }

  .cluster-count {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  /* ── Popup ─────────────────────────────────────────────── */
  .map-popup {
    position: absolute;
    transform: translate(-50%, -100%);
    background: var(--white);
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    padding: 1rem;
    min-width: 220px;
    max-width: 280px;
    z-index: 10;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .map-popup.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  .map-popup::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 8px solid var(--white);
  }

  .map-popup.popup--below {
    transform: translate(-50%, 0);
  }

  .map-popup.popup--below::after {
    top: -8px;
    bottom: auto;
    border-top: none;
    border-bottom: 8px solid var(--white);
  }

  .popup-close {
    position: absolute;
    top: 0.25rem;
    right: 0.5rem;
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--gray);
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
  }

  .popup-close:hover {
    color: var(--navy);
  }

  :global(.popup-item) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0;
    color: var(--navy);
    text-decoration: none;
    font-family: var(--font-body);
  }

  :global(.popup-item + .popup-item) {
    border-top: 1px solid var(--gray-light);
  }

  :global(.popup-item--link) {
    transition: color 0.2s ease;
  }

  :global(.popup-item--link:hover) {
    color: var(--red);
  }

  :global(.popup-item strong) {
    display: block;
    font-size: 0.8125rem;
    font-weight: 700;
  }

  :global(.popup-handle) {
    display: block;
    font-size: 0.6875rem;
    color: var(--gray);
    margin-top: 1px;
  }

  :global(.popup-item svg) {
    flex-shrink: 0;
    color: var(--red);
  }

  /* ── List below map ────────────────────────────────────── */
  .mcu-list {
    margin-top: 3rem;
  }

  .mcu-list-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

