---
const stats = [
  { value: 45, suffix: '+', label: 'Años', desc: 'evangelizando universitarios' },
  { value: 15, suffix: '+', label: 'MSUs', desc: 'en todo México' },
  { value: 200, suffix: '+', label: 'Misioneros', desc: 'universitarios' },
  { value: 450, suffix: '+', label: 'Asambleas', desc: 'universitarias de oración al año' },
];
---

<section class="stats-bar">
  <div class="stats-bar__bg"></div>
  <div class="stats-bar__inner">
    {stats.map((stat) => (
      <div class="stats-bar__item">
        <span class="stats-bar__number" data-target={stat.value} data-suffix={stat.suffix}>
          0{stat.suffix}
        </span>
        <span class="stats-bar__label">{stat.label}</span>
        <span class="stats-bar__desc">{stat.desc}</span>
      </div>
    ))}
  </div>
</section>

<script>
  function animateCountUp(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';
    const duration = 1500;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = `${current}${suffix}`;
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll<HTMLElement>('.stats-bar__number').forEach(animateCountUp);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('.stats-bar').forEach((el) => observer.observe(el));
</script>

<style>
  .stats-bar {
    position: relative;
    padding: 5rem 1.5rem;
    overflow: hidden;
  }

  .stats-bar__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, #0a1628 0%, #162a4a 40%, #0f1f3a 70%, #0a1628 100%);
    z-index: 0;
  }

  .stats-bar__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 600px 300px at 20% 50%, rgba(230, 52, 98, 0.08), transparent),
      radial-gradient(ellipse 500px 400px at 80% 30%, rgba(22, 42, 74, 0.6), transparent);
  }

  .stats-bar__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 1;
  }

  .stats-bar__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stats-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stats-bar__number {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 10vw, 5.5rem);
    color: var(--white);
    letter-spacing: 2px;
    line-height: 1;
  }

  .stats-bar__label {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--red);
    margin-top: 0.25rem;
  }

  .stats-bar__desc {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.5rem;
    max-width: 180px;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .stats-bar {
      padding: 3.5rem 1rem;
    }

    .stats-bar__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 1.5rem;
    }
  }
</style>
