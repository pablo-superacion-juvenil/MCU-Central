---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Objetivos from '../components/Objetivos.astro';
import PhotoDivider from '../components/PhotoDivider.astro';
import Historia from '../components/Historia.astro';
import Footer from '../components/Footer.astro';

import portada1 from '../assets/images/portada/portada-1.jpg';
import portada3 from '../assets/images/portada/portada-3.jpg';
import portada5 from '../assets/images/portada/portada-5.jpg';
---

<Layout title="Nosotros — MCU">
  <Nav currentPage="nosotros" />
  <PageHero title="Quiénes Somos" />
  <Objetivos />
  <PhotoDivider image={portada1} alt="Comunidad MCU" />
  <Historia />
  <PhotoDivider image={portada5} alt="Evento MCU" />
  <Footer />
</Layout>
