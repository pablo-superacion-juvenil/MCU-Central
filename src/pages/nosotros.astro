---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Objetivos from '../components/Objetivos.astro';
import PhotoDivider from '../components/PhotoDivider.astro';
import Creencias from '../components/Creencias.astro';
import Historia from '../components/Historia.astro';
import Footer from '../components/Footer.astro';

import portada1 from '../assets/images/portada/portada-1.jpg';
import portada5 from '../assets/images/portada/portada-5.jpg';
---

<Layout title="Nosotros — MCU">
  <Nav currentPage="nosotros" />
  <PageHero title="Quiénes Somos" />
  <PhotoDivider
    image={portada1}
    alt="Asamblea de evangelización MCU"
    height="500px"
    position="center 60%"
  />
  <Objetivos />
  <Creencias />
  <Historia />
  <PhotoDivider
    image={portada5}
    alt="Hermanos de MCU"
    height="500px"
    position="center 30%"
  />
  <Footer />
</Layout>
