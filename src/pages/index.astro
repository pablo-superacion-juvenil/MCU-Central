---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import SectionTeaser from '../components/SectionTeaser.astro';
import PhotoDivider from '../components/PhotoDivider.astro';
import QueHacemos from '../components/QueHacemos.astro';
import Footer from '../components/Footer.astro';

import nosotros2 from '../assets/images/nosotros/nosotros-2.jpg';
import portada2 from '../assets/images/portada/portada-2.jpg';
import portada4 from '../assets/images/portada/portada-4.jpg';
---

<Layout title="MCU — Misión Católica Universitaria">
  <Nav currentPage="home" />
  <Hero />
  <StatsBar />
  <PhotoDivider
    image={portada2}
    alt="Comunidad MCU reunida"
    height="400px"
    position="center 40%"
  />
  <SectionTeaser
    title="Quiénes Somos"
    description="MISIÓN CATÓLICA UNIVERSITARIA es un movimiento católico de jóvenes, que se dedica a evangelizar a jóvenes universitarios, llevarlos a un compromiso con Cristo y con otros cristianos y proveerles de formación en carácter cristiano."
    image={nosotros2}
    imageAlt="Miembros de MCU reunidos"
    href="/nosotros"
    buttonText="Conócenos"
  />
  <PhotoDivider
    image={portada4}
    alt="Jóvenes de MCU"
    height="600px"
    position="center top"
  />
  <QueHacemos />
  <Footer />
</Layout>
